# Supabase PostgreSQL: use Direct connection for a persistent backend when IPv6 is available.
# Otherwise use the Supavisor Session pooler on port 5432.
SUPABASE_DB_JDBC_URL=jdbc:postgresql://db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=change-me
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1

# Supabase Auth JWT verification.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_change_me
# Backend only. Never expose this key to web/mobile clients.
SUPABASE_SECRET_KEY=sb_secret_change_me
SUPABASE_JWT_ISSUER=https://PROJECT_REF.supabase.co/auth/v1
SUPABASE_JWKS_URI=https://PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
AUTH_EMAIL_REDIRECT_URL=http://localhost:3000/auth/confirm
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
# One-time, idempotent bootstrap. Once an ADMIN exists, these values are ignored.
AUTH_BOOTSTRAP_ADMIN_EMAIL=
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
SUPABASE_PUBLIC_STORAGE_URL=https://PROJECT_REF.supabase.co/storage/v1/object/public

# Local infrastructure.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Public gateway URLs.
CORS_ALLOWED_ORIGIN_PATTERN=http://localhost:*
USER_CRM_SERVICE_URL=http://localhost:8081
CATALOG_INVENTORY_SERVICE_URL=http://localhost:8082
COMMERCE_SERVICE_URL=http://localhost:8083
AFTERSALES_SERVICE_URL=http://localhost:8084
AUTOMATION_SERVICE_URL=http://localhost:8085
COMMUNICATION_SERVICE_URL=http://localhost:8086
INTEGRATION_REPORTING_SERVICE_URL=http://localhost:8087
